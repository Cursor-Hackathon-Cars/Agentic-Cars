# ── Backend ──────────────────────────────────────────────────────────────────
# URL of your running backend server
BACKEND_URL=http://localhost:3000

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Camera snapshot (optional) ────────────────────────────────────────────────
# Defaults to {BACKEND_URL}/camera/snapshot (proxied through the backend).
# Override to hit go2rtc directly if you're on the same network as the Pi.
# CAMERA_SNAPSHOT_URL=http://192.168.1.50:1984/api/frame.jpeg?src=camera

# ── Zapbox Link (optional) ────────────────────────────────────────────────────
# Leave blank or unset for agent-only mode (no manual controller).
# ZAPBOX_LINK_URL=ws://192.168.1.60:8080

# ── Copilot tuning ────────────────────────────────────────────────────────────
# Seconds of controller inactivity before the AI agent takes over (default 3)
INACTIVITY_SEC=3.0

# Seconds between vision analysis calls (default 1.0, lower = more responsive)
AGENT_INTERVAL=1.0

# Degrees of tilt required to register a drive input (default 15)
TILT_THRESHOLD=15.0
