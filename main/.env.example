# =============================================================================
# Agentic Cars environment template
# Used by: main/copilot.py, main/agent.py, main/zapbox_link.py, backend/main.py
# =============================================================================

# ── Main / Copilot ────────────────────────────────────────────────────────────
# URL of your running backend server (used by copilot + agent)
BACKEND_URL=http://localhost:3000

# Toggle autonomous AI driving:
#   1 = enabled (OpenAI prompts may be sent)
#   0 = disabled (no OpenAI prompts are sent)
AGENTIC_MODE=1

# OpenAI API key (required only when AGENTIC_MODE=1)
OPENAI_API_KEY=sk-...

# Optional camera snapshot override for the AI agent:
# Defaults to {BACKEND_URL}/camera/snapshot
# CAMERA_SNAPSHOT_URL=http://192.168.1.50:1984/api/frame.jpeg?src=camera

# Zapbox controller WebSocket server port
ZAPBOX_PORT=8080

# Copilot tuning
INACTIVITY_SEC=3.0
AGENT_INTERVAL=1.0
TILT_THRESHOLD=15.0


# ── Backend / Camera Source ───────────────────────────────────────────────────
# Backend HTTP port
PORT=3000

# Raspberry Pi go2rtc source (used when USE_LAPTOP_CAMERA=0)
PI_IP=172.20.10.2
GO2RTC_PORT=1984

# Test mode camera source:
#   0 = use Pi/go2rtc camera
#   1 = use local laptop webcam
USE_LAPTOP_CAMERA=0

# Local webcam settings (used only when USE_LAPTOP_CAMERA=1)
LAPTOP_CAMERA_INDEX=0
LAPTOP_CAMERA_WIDTH=1280
LAPTOP_CAMERA_HEIGHT=720
LAPTOP_CAMERA_FPS=20
LAPTOP_CAMERA_JPEG_QUALITY=80
